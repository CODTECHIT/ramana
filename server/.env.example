PORT=5000
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xyz.mongodb.net/<dbname>?retryWrites=true&w=majority"

JWT_ACCESS_SECRET="your_jwt_access_secret_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD="a_strong_local_password"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET="rzp_test_secret"

# SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="smtp_user"
SMTP_PASS="smtp_password"
SMTP_FROM="Your App <noreply@example.com>"

FRONTEND_URL=http://localhost:3000

# NOTE: Copy this file to 'server/.env' and fill real values. Never commit real secrets.
PORT=5000
MONGODB_URI=mongodb://localhost:27017/ramana-jewells
JWT_ACCESS_SECRET=your_super_secret_access_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# Cloudinary Setup for Image Uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Initial Admin Seeding
SEED_ADMIN_EMAIL=admin@ramanajewells.com
SEED_ADMIN_PASSWORD=adminpassword123

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (SMTP) Configuration — Leave blank to use auto-generated Ethereal dev mailbox
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Ramana Jewells <no-reply@ramanajewells.com>

# Frontend URL (used in reset password email links)
FRONTEND_URL=http://localhost:3000
