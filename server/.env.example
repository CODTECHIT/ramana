PORT=5000
MONGODB_URI=mongodb://localhost:27017/ramana-jewells
JWT_ACCESS_SECRET=your_super_secret_access_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# Cloudinary Setup for Image Uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Initial Admin Seeding
SEED_ADMIN_EMAIL=admin@ramanajewells.com
SEED_ADMIN_PASSWORD=adminpassword123

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (SMTP) Configuration — Leave blank to use auto-generated Ethereal dev mailbox
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Ramana Jewells <no-reply@ramanajewells.com>

# Frontend URL (used in reset password email links)
FRONTEND_URL=http://localhost:3000
